# App
APP_NAME="YouTube Intelligent Classifier"
SECRET_KEY="change-me-generate-with-openssl-rand-hex-32"
DEBUG=false
ENVIRONMENT="production"

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ytclassifier
POSTGRES_USER=postgres
POSTGRES_PASSWORD="strong-password-here"

# MongoDB
MONGO_URI="mongodb://localhost:27017"
MONGO_DB="ytclassifier_docs"

# Redis
REDIS_URL="redis://localhost:6379/0"

# Celery
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"

# ML Models
WHISPER_MODEL_SIZE="base"
WHISPER_DEVICE="cpu"
TORCH_DEVICE="cpu"
YOLO_MODEL_PATH="yolov8n.pt"
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.65

# OCR (set path on Windows)
# TESSERACT_CMD="C:/Program Files/Tesseract-OCR/tesseract.exe"

# Third-party APIs (optional)
TMDB_API_KEY=""
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REDIRECT_URI="http://localhost:8000/api/v1/auth/spotify/callback"

# CORS
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173"

# Rate limiting
RATE_LIMIT_PER_MINUTE=300

# Intelligence Layer (Gemini LLM Brain)
# Get a free API key at https://aistudio.google.com/app/apikey
# Free tier: 15 RPM, 1500 requests/day (sufficient for development)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
BRAIN_CONFIDENCE_THRESHOLD=0.85
LLM_FALLBACK_ENABLED=true
