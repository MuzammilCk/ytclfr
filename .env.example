# ==============================================================================
# YTCLFR Environment Configuration
# Copy this file to .env and configure it for your environment
# ==============================================================================

# ── App Environment ───────────────────────────────────────────────────────────
APP_NAME="YouTube Intelligent Classifier"
APP_VERSION="1.0.0"
DEBUG=False
# Use 'development' for local runs, 'production' for deployments
ENVIRONMENT=production 
# Public URL used to generate frame URLs (e.g., http://localhost:8000)
PUBLIC_BASE_URL=http://localhost:8000

# 🔴 SECURITY CRITICAL 🔴
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY="change-me-in-production-use-openssl-rand-hex-32"

# Allowed origins for CORS (e.g. your frontend, comma separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Error Tracking ────────────────────────────────────────────────────────────
# SENTRY_DSN=https://your-dsn@sentry.io/123

# ── Database Configurations ───────────────────────────────────────────────────
# Postgres (Auth, Users, API State)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ytclassifier
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# MongoDB (Document Store for Analysis JSON blobs)
# If using MongoDB Atlas, set MONGO_URL. Otherwise, MONGO_URI is used.
# MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://mongo:27017
MONGO_DB=ytclassifier_docs

# Redis (Caching & Celery Broker)
REDIS_URL=redis://redis:6379/0

# ── Celery Configurations ─────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Whisper Options ───────────────────────────────────────────────────────────
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu # Change to 'cuda' to utilize GPU acceleration

# ── ML / Vision Configs ───────────────────────────────────────────────────────
TORCH_DEVICE=cpu # Change to 'cuda' when running on GPU
FRAME_SAMPLE_FPS=1.0
YOLO_CONFIDENCE=0.45

# ── External Integrations ─────────────────────────────────────────────────────
# Spotify Integration (Optional: Enables auto-playlist generation)
# SPOTIFY_CLIENT_ID=your-spotify-client-id
# SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# TMDb Integration (Optional: Enables movie lists/TV show enrichment)
# TMDB_API_KEY=your-tmdb-v3-api-key

# Google Books Integration (Optional: Enables book-list enrichment with author, ISBN, purchase links)
# GOOGLE_BOOKS_API_KEY=your-google-books-api-v1-key
